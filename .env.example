# Root .env consumed by docker-compose.
# Copy to .env and edit as needed. The .env file is gitignored.

# --- Postgres ---
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader
POSTGRES_DB=trading_sim

# --- Backend ---
DEMO_USER_USERNAME=demo
DEMO_USER_STARTING_CASH=10000
PRICE_SOURCE=simulated
PRICE_TICK_SECONDS=3
TRACKED_SYMBOLS=AAPL,TSLA,GOOG,MSFT,AMZN
FRONTEND_ORIGIN=http://localhost:5173

# Set when PRICE_SOURCE=alphavantage. Get a free key at
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# --- Frontend (baked into the bundle at build time) ---
VITE_API_BASE=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
