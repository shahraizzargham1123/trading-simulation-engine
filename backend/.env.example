# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored — never commit it.

# --- Database ---
DATABASE_URL=postgresql+psycopg2://trader:trader@localhost:5432/trading_sim

# --- Demo user seed ---
DEMO_USER_USERNAME=demo
DEMO_USER_STARTING_CASH=10000

# --- Pricing engine ---
# Options: "simulated" (default, no API needed) or "alphavantage"
PRICE_SOURCE=simulated

# Tick interval in seconds for the price broadcaster
PRICE_TICK_SECONDS=3

# Comma-separated tickers the simulator/API will track
TRACKED_SYMBOLS=AAPL,TSLA,GOOG,MSFT,AMZN

# --- Alpha Vantage (only needed if PRICE_SOURCE=alphavantage) ---
# Get a free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:5173
